@article{axen2011radhardness,
    title = {Diamond detector irradiation tests  at TRIUMF},
    author = {David Axen and  Frederick Dallaire and  Claire David and  Margret Fincke-Keeler and  Leonid Kurchaninov and  Richard Keeler and  Peter Krieger and  Claude Leroy and  Robert McPherson and  Gerald Oakham and  Paul Poffenberger and  Koloina Randrianarivony and  Yun-Ha Shin and  Isabel Trigger and  Joshua Turner},
    doi = {10.1088/1748-0221/6/05/P05011},
    url = {https://dx.doi.org/10.1088/1748-0221/6/05/P05011},
    year = {2011},
    publisher = {},
    volume = {6},
    number = {05},
    pages = {P05011},
    journal = {Journal of Instrumentation},
    abstract = {Polycrystalline chemical vapour deposition (pCVD) diamond detectors are being considered for an upgrade of Forward Calorimetry in the ATLAS detector at the CERN LHC. In order to determine their radiation hardness, four detectors  were continuously monitored during irradiation with 500 MeV protons at TRIUMF to a fluence of 2.25 x 10<sup>17</sup> protons/cm<sup>2</sup>. All four detectors worked at the end of the irradiation period. The detector response A as a function of fluence has been fitted to a sum of two exponentials and to a  function  A = a<sub>o</sub>/(1+a<sup>1</sup>&phi;) where ao is the initial response and &phi; is the fluence with a<sub>1</sub> = 9.8 x 10<sup>−17</sup> ± 3.2 x 10<sup>−18</sup> cm<sup>2</sup>/proton. At the end of irradiation the response had reduced to five percent of the original value. The time resolution was found to be  ∼  250 picoseconds.},

    website = {https://iopscience.iop.org/article/10.1088/1748-0221/13/01/C01003/meta},
    pdf = {https://iopscience.iop.org/article/10.1088/1748-0221/6/05/P05011/pdf}
}

@article{david2018itktrackerproc,
    title = {A new strips tracker for the upgraded ATLAS ITk detector},
    author = {Claire David},
    doi = {10.1088/1748-0221/13/01/C01003},
    url = {https://dx.doi.org/10.1088/1748-0221/13/01/C01003},
    year = {2018},
    publisher = {},
    volume = {13},
    number = {01},
    pages = {C01003},
    journal = {Journal of Instrumentation},
    abstract = {The ATLAS detector has been designed and developed to function in the environment of the present Large Hadron Collider (LHC). At the next-generation tracking detector proposed for the High Luminosity LHC (HL-LHC), the so-called ATLAS Phase-II Upgrade, the fluences and radiation levels will be higher by as much as a factor of ten. The new sub-detectors must thus be faster, of larger area, more segmented and more radiation hard while the amount of inactive material should be minimized and the power supply to the front-end systems should be increased. For those reasons, the current inner tracker of the ATLAS detector will be fully replaced by an all-silicon tracking system that consists of a pixel detector at small radius close to the beam line and a large area strip tracker surrounding it. This document gives an overview of the design of the strip inner tracker (Strip ITk) and summarises the intensive R&amp;D activities performed over the last years by the numerous institutes within the Strips ITk collaboration. These studies are accompanied with a strong prototyping effort to contribute to the optimisation of the Strip ITk's structure and components. This effort culminated recently in the release of the ATLAS Strips ITk Technical Design Report (TDR).},

    website = {https://iopscience.iop.org/article/10.1088/1748-0221/13/01/C01003/meta},
    pdf = {https://iopscience.iop.org/article/10.1088/1748-0221/13/01/C01003/pdf}
}

@article{david2016susyposter,
    title = {Search for chargino and neutralino production with a Higgs boson in the decay chain in one or three leptons final state events with ATLAS},
    author = {Claire David},
    journal = {Nuclear and Particle Physics Proceedings},
    volume = {273-275},
    pages = {2400-2402},
    year = {2016},
    note = {37th International Conference on High Energy Physics (ICHEP)},
    issn = {2405-6014},
    doi = {https://doi.org/10.1016/j.nuclphysbps.2015.09.405},
    url = {https://www.sciencedirect.com/science/article/pii/S2405601415008949},
    abstract = {Searches for direct production of chargino (χ˜1±) and neutralino (χ˜20) leading to final states characterized by the presence of a Higgs boson are reported. Events containing missing transverse momentum and one or three leptons are selected, and various channels sensitive to different Higgs decays are considered. The analyses use 20.3 fb-1 of proton-proton collision data at s=8 TeV recorded in 2012 with the ATLAS detector at the Large Hadron Collider. Observations are consistent with the Standard Model expectations and limits are set in R-parity conserving phenomenological Minimal Supersymmetric Standard Models and in simplified supersymmetric models.},

    pdf = {https://www.sciencedirect.com/science/article/pii/S2405601415008949/pdf?md5=1af90e4dfad15856cc2b05d8d7278d31&pid=1-s2.0-S2405601415008949-main.pdf},
    website = {https://www.sciencedirect.com/science/article/pii/S2405601415008949?via%3Dihub},
    poster = {https://cds.cern.ch/record/1745959/files/ATL-PHYS-SLIDE-2014-486.pdf}
}

@article{david2014procICNFP,
	title = {New ATLAS results in SUSY searches for 3<sup>rd</sup> generation squarks and electroweak production},
	author = {Claire David},
	DOI= {10.1051/epjconf/20147100034},
	url= {https://doi.org/10.1051/epjconf/20147100034},
	journal = {EPJ Web of Conferences},
	year = {2014},
	volume = {71},
	pages = {00034},
  abstract = {Naturalness arguments for weak-scale supersymmetry favour supersymmetric partners of the third generation quarks with masses close to those of their Standard Model counterparts. Real and virtual production of third generation squarks via decay of a gluino can be significant if the mass of the gluino does not exceed the TeV scale. Top or bottom squarks with masses less than a few hundred GeV can also give rise to direct pair production rates at the LHC that can be observed in the 8 TeV data sample recorded by the ATLAS detector. Moreover, many supersymmetric models feature neutralinos, charginos and even sleptons with masses less than a few hundred GeV so that they can be observed in the available data sample. The talk presents recent ATLAS results from searches for direct stop and sbottom pair production as well as pair production of charginos, neutralinos and sleptons.},

  pdf = {www.epj-conferences.org/articles/epjconf/pdf/2014/08/epjconf_icnfp2013_00034.pdf}
}





